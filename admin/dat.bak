<script type="text/javascript">

    window.onload = function() { jam(); }
   var d = new Date().getDay;
    function jam() {
     var e = document.getElementById('jam'),
     d = new Date(), h, m, s;
     h = d.getHours();
     m = set(d.getMinutes());
     s = set(d.getSeconds());
   
     e.value = d.toDateString() +' || '+ h +'.'+ m +'.'+ s +'';
   
     setTimeout('jam()', 1000);
    }
   
    function set(e) {
     e = e < 10 ? '0'+ e : e;
     return e;
    }
   </script>

